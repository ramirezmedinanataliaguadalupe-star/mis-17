1000
);

actualizarCuenta();

function crearFlor(){

let flor=
document
.createElement(
"div"
);

flor.className=
"flor";

let flores=
["🌷","🌸","🌼","💮"];

flor.innerHTML=
flores[
Math.floor(
Math.random()*4
)];

flor.style.left=
Math.random()*100+
"vw";

flor.style.animationDuration=
(4+
Math.random()*5)
+"s";

document
.body
.appendChild(
flor
);

setTimeout(()=>{

flor.remove();

},9000);

}

setInterval(
crearFlor,
350
);

</script>

</body>

</html>

